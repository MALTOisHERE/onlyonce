# Copy to .env for local overrides (never commit .env)
# On hosting platforms (Railway, Render, Heroku) set these via the dashboard instead.

# Set to "production" to enable HTTPS redirect and HSTS header
NODE_ENV=development

# Port to listen on (defaults to 3000)
PORT=3000

# Required in production to enable HTTPS redirect without open-redirect risk
# Must be your exact domain, e.g: yourdomain.com
HOST=

# Permanent server-side secret for K3 HMAC binding (strongly recommended)
# Each secret's K2 is masked with HMAC(K3, secret_id) before storage.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Permanent server-side key for K4 ciphertext encryption (strongly recommended)
# Ciphertext is re-encrypted with K4 before storage — mandatory for any decryption.
# Generate with: openssl rand -hex 32
CIPHER_KEY=

# Resend API key for email OTP verification (optional feature)
# Sign up at resend.com, verify your domain, then paste your key here
RESEND_API_KEY=

# Sender address shown in OTP emails (must match your verified Resend domain)
EMAIL_FROM=Blink <noreply@yourdomain.com>

# ── Blink Pro (Lemon Squeezy licensing) ──────────────────────────────────────
# Pin license validation to YOUR store and product. Without these, license keys
# from ANY Lemon Squeezy store would unlock Pro.
# Store ID: Settings -> Stores (the #number). Product ID: "Copy ID" on the product.
LS_STORE_ID=
LS_PRODUCT_ID=

# Public Lemon Squeezy checkout URL (product Share link). Shown on the "Get Pro"
# buttons. Leave empty to hide the buy button (license activation still works).
PRO_CHECKOUT_URL=

# Dev-only master key that unlocks Pro locally. NEVER set this in production.
BLINK_PRO_DEV_KEY=
