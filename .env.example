# Copy to .env for local overrides (never commit .env)
# On hosting platforms (Railway, Render, Heroku) set these via the dashboard instead.

# Set to "production" to enable HTTPS redirect and HSTS header
NODE_ENV=development

# Port to listen on (defaults to 3000)
PORT=3000

# Required in production to enable HTTPS redirect without open-redirect risk
# Must be your exact domain, e.g: yourdomain.com
HOST=

# Permanent server-side secret for K3 HMAC binding (strongly recommended)
# Each secret's K2 is masked with HMAC(K3, secret_id) before storage.
# If an attacker dumps server memory, K2 alone is useless without K3.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Resend API key for email OTP verification (optional feature)
# Sign up at resend.com, verify your domain, then paste your key here
RESEND_API_KEY=

# Sender address shown in OTP emails (must match your verified Resend domain)
EMAIL_FROM=Blink <noreply@yourdomain.com>
