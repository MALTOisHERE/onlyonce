# Copy to .env for local overrides (never commit .env)
# On hosting platforms (Railway, Render, Heroku) set these via the dashboard instead.

# Set to "production" to enable HTTPS redirect and HSTS header
NODE_ENV=development

# Port to listen on (defaults to 3000)
PORT=3000

# Required in production to enable HTTPS redirect without open-redirect risk
# Must be your exact domain, e.g: yourdomain.com
HOST=

# Permanent server-side secret for K3 HMAC binding (strongly recommended)
# Each secret's K2 is masked with HMAC(K3, secret_id) before storage.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Permanent server-side key for K4 ciphertext encryption (strongly recommended)
# Ciphertext is re-encrypted with K4 before storage — mandatory for any decryption.
# Generate with: openssl rand -hex 32
CIPHER_KEY=

# Resend API key for email OTP verification (optional feature)
# Sign up at resend.com, verify your domain, then paste your key here
RESEND_API_KEY=

# Sender address shown in OTP emails (must match your verified Resend domain)
EMAIL_FROM=Blink <noreply@yourdomain.com>

# ── Blink Pro (Lemon Squeezy licensing) ──────────────────────────────────────
# Pin license validation to YOUR store and product. Without these, license keys
# from ANY Lemon Squeezy store would unlock Pro.
# Store ID: Settings -> Stores (the #number). Product ID: "Copy ID" on the product.
# IMPORTANT: on the product's License Keys settings, set "Activation Limit" to 1.
# Blink binds each key to exactly one signed-in Google account (see the Google
# Sign-In section below) — Activation Limit = 1 is what Lemon Squeezy enforces
# on its side to match that: no other account can ever activate the same key.
LS_STORE_ID=
LS_PRODUCT_ID=

# Public Lemon Squeezy checkout URL (product Share link). Shown on the "Get Pro"
# buttons. Leave empty to hide the buy button (license activation still works).
PRO_CHECKOUT_URL=

# Dev-only master key. Enables local Pro testing via GET /api/auth/dev-login
# (fakes a Google login, no real credentials needed) and lets that fake session
# activate Pro with this exact key value. NEVER set this in production.
BLINK_PRO_DEV_KEY=

# Max Pro secret creations per signed-in account per 24h (default 50). A
# secondary safety net against runaway/automated abuse of one account — the
# primary protection is that Pro requires a live Google session, not a
# copy-pasteable key.
PRO_USAGE_RATE_LIMIT=50

# ── Blink Pro sign-in (Google OAuth) ─────────────────────────────────────────
# Required for real users to activate Pro. Setup in Google Cloud Console:
#   1. console.cloud.google.com -> select/create a project
#   2. APIs & Services -> OAuth consent screen -> External -> fill in app name/
#      support email -> scopes: just "openid" and "email" (no sensitive scopes,
#      so this avoids Google's extended verification review)
#   3. APIs & Services -> Credentials -> Create Credentials -> OAuth client ID
#      -> Application type: Web application
#   4. Authorized redirect URIs: add GOOGLE_REDIRECT_URI's exact value below
#      (must match exactly, including https:// and no trailing slash)
#   5. Copy the generated Client ID and Client Secret into the two vars below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in the Google Cloud console
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# Signs the session cookie proving a Google account is logged in. Required for
# Pro sign-in to work at all. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional override for where the Google-account -> license mapping is stored.
# Defaults to data/licenses.json, alongside stats.json on the same Docker volume.
LICENSES_FILE=
